# Copy this file to deploy/remote/.env before using Docker Compose.
#
# Generate a strong token, then paste the output below:
#   openssl rand -hex 32
# Docker Compose refuses to start while this value is empty.
SYNARA_AUTH_TOKEN=

# Published listener. Keep loopback unless a firewall or trusted private network
# is intentionally protecting direct access. A reverse proxy on the same host
# can reach the default loopback listener.
SYNARA_BIND_ADDRESS=127.0.0.1
SYNARA_HOST_PORT=3773

# Host directory mounted at /workspace. Relative paths are resolved from
# deploy/remote; an absolute path is clearer on production hosts.
SYNARA_WORKSPACE_PATH=./workspace

# Match the owner of SYNARA_WORKSPACE_PATH so agents can edit repositories.
SYNARA_UID=1000
SYNARA_GID=1000

# Optional operational overrides.
SYNARA_IMAGE=synara-remote:local
SYNARA_HOME_VOLUME=synara-remote-home
SYNARA_STOP_GRACE_PERIOD=30s

# Optional prefix for GitHub Release downloads during image builds on networks
# that cannot reach github.com directly, for example https://ghproxy.net/.
GITHUB_DOWNLOAD_PREFIX=
