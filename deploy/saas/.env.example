# Required secrets. Generate independent values for each deployment.
POSTGRES_PASSWORD=
MINIO_ROOT_USER=synara
MINIO_ROOT_PASSWORD=
SYNARA_AUTH_TOKEN=
SYNARA_WORKER_REGISTRATION_TOKEN=
# Base64-encoded 32-byte key. Generate with: openssl rand -base64 32
SYNARA_PROVIDER_CURSOR_KEY=

# PostgreSQL pool and bounded concurrent-startup migration coordination.
SYNARA_DATABASE_MAX_OPEN_CONNECTIONS=20
SYNARA_DATABASE_MAX_IDLE_CONNECTIONS=5
SYNARA_DATABASE_CONNECTION_MAX_LIFETIME=1h
SYNARA_DATABASE_CONNECTION_MAX_IDLE_TIME=15m
SYNARA_DATABASE_MIGRATION_LOCK_TIMEOUT=30s

# Provider Credential envelope encryption. The Compose default uses a local
# 32-byte KEK; production may switch the provider to aws-kms and configure an
# AWS KMS key ID/region instead of a local master key.
SYNARA_CREDENTIAL_KMS_PROVIDER=local
SYNARA_CREDENTIAL_KMS_KEY_ID=single-node-local-v1
SYNARA_CREDENTIAL_MASTER_KEY=
SYNARA_CREDENTIAL_KMS_AWS_REGION=

# Public HTTPS origin that SSH/Kubernetes Workers use to call the control plane.
SYNARA_PUBLIC_CONTROL_PLANE_URL=
SYNARA_SSH_PROVISION_TIMEOUT=2m
SYNARA_DOCKER_RECONCILE_INTERVAL=10s
SYNARA_KUBERNETES_RECONCILE_INTERVAL=5s
SYNARA_RETENTION_SWEEP_INTERVAL=1h
SYNARA_OUTBOX_POLL_INTERVAL=500ms
SYNARA_OUTBOX_CLAIM_TTL=30s
SYNARA_OUTBOX_BATCH_SIZE=50
SYNARA_OUTBOX_MAX_ATTEMPTS=12
SYNARA_OUTBOX_BASE_BACKOFF=1s
SYNARA_OUTBOX_MAX_BACKOFF=5m

# Used only with docker-workers.override.yml. On Linux, set the numeric group
# that owns the Docker socket (`stat -c %g /var/run/docker.sock`).
SYNARA_DOCKER_SOCKET_PATH=/var/run/docker.sock
SYNARA_DOCKER_GID=0

# MinIO/S3 Artifact Store. The public endpoint is embedded in presigned URLs and
# must be reachable by the browser or API client.
MINIO_BIND_ADDRESS=127.0.0.1
MINIO_PUBLIC_HOST=127.0.0.1
MINIO_HOST_PORT=59000
SYNARA_ARTIFACT_BUCKET=synara-artifacts
SYNARA_ARTIFACT_REGION=us-east-1
SYNARA_ARTIFACT_PRESIGN_TTL=15m
SYNARA_ARTIFACT_MAX_UPLOAD_BYTES=2147483648
SYNARA_ARTIFACT_CORS_ALLOW_ORIGIN=http://127.0.0.1:3773

# This Compose deployment is the supported v1 single-node profile.
SYNARA_DEPLOYMENT_PROFILE=single-node
SYNARA_METADATA_STORE=postgresql
SYNARA_ARTIFACT_STORE=minio
SYNARA_QUEUE_DRIVER=postgres-outbox
SYNARA_CONTROL_PLANE_REPLICAS=1
SYNARA_WORKER_LEASES_ENABLED=true
SYNARA_WORKER_FENCING_ENABLED=true

# The temporary local identity bootstrap is useful for development and acceptance testing.
# Keep it false in production; enterprise OIDC/SAML arrives in a later phase.
SYNARA_CONTROL_PLANE_DEV_BOOTSTRAP=false
SYNARA_LOGIN_COOKIE_SECURE=true
SYNARA_LOGIN_COOKIE_DOMAIN=
SYNARA_LOGIN_COOKIE_PATH=/
SYNARA_LOGIN_COOKIE_SAME_SITE=lax
SYNARA_LOGIN_SESSION_TTL=720h
SYNARA_LOGIN_SESSION_IDLE_TTL=168h
# Comma-separated CIDRs of reverse proxies allowed to supply X-Forwarded-For.
SYNARA_TRUSTED_PROXY_CIDRS=
SYNARA_WORKER_LEASE_TTL=30s
SYNARA_WORKER_HEARTBEAT_TIMEOUT=90s
SYNARA_WORKER_RECEIPT_TTL=24h

# Public Synara listener.
SYNARA_BIND_ADDRESS=127.0.0.1
SYNARA_HOST_PORT=3773

# Host workspace mounted into the existing TypeScript Provider Runtime.
SYNARA_WORKSPACE_PATH=./workspace
SYNARA_UID=1000
SYNARA_GID=1000
SYNARA_IMAGE=synara-saas:local

# Optional Go module proxy for networks that cannot reach proxy.golang.org.
GOPROXY=https://proxy.golang.org,direct

# Optional prefix for GitHub Release downloads during the Synara image build.
GITHUB_DOWNLOAD_PREFIX=
