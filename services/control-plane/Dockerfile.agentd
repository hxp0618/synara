# syntax=docker/dockerfile:1.7

FROM golang:1.26-alpine AS build
ARG GOPROXY=https://proxy.golang.org,direct
ENV GOPROXY=${GOPROXY}
WORKDIR /src
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod go mod download
COPY . .
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/synara-agentd ./cmd/agentd

FROM alpine:3.22
RUN apk add --no-cache ca-certificates git openssh-client && \
    addgroup -g 10002 -S synara-agentd && \
    adduser -u 10002 -S -D -H -G synara-agentd synara-agentd && \
    mkdir -p /data/workspaces && chown -R 10002:10002 /data
COPY --from=build /out/synara-agentd /usr/local/bin/synara-agentd
USER 10002:10002
ENV SYNARA_AGENTD_WORKSPACE_ROOT=/data/workspaces
ENTRYPOINT ["/usr/local/bin/synara-agentd"]
